DB_CLIENT=postgres
PG_HOST=127.0.0.1
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=
PG_DATABASE=ultima_web
JWT_SECRET=ultima-demo-secret
PORT=4001
API_URL=http://localhost:4001
VITE_API_URL=http://localhost:4001
PUBLIC_WEB_BASE_URL=http://localhost:5173
SMTP_HOST_DOCKER=mailpit
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Redis (optional — leave blank to skip; docker-compose sets this automatically)
REDIS_URL=redis://127.0.0.1:6379

# SmartPlay AI microservice (leave blank until AI backend is deployed)
SMARTPLAY_AI_URL=
SMARTPLAY_GENERATE_BROWSER_PREVIEW=1
FFMPEG_PATH=ffmpeg

# Stripe (court & coach payments)
# Get keys from https://dashboard.stripe.com/apikeys
# TND is not a native Stripe currency — amounts are charged in EUR (1 TND ≈ 0.30 EUR)
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_
